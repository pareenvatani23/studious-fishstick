# Copy to .env (gitignored) for the AI prototype. EXPO_PUBLIC_* are inlined into
# the client bundle — fine for a PROTOTYPE only. For production these must move
# behind a backend; never ship client-side keys.
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_ELEVENLABS_API_KEY=
# Calm, reassuring default voice ("Sarah"). Override with any ElevenLabs voice id.
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# Supabase (publishable key is safe client-side; works with RLS). URL + anon key.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
